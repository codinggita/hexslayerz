{
  "manifest_version": 3,
  "name": "LSCS — Local Summarization Checkpoint System",
  "description": "Locally summarize and checkpoint your ChatGPT conversations.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LSCS v2"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {},
  "host_permissions": ["<all_urls>"],
  "permissions": ["storage", "activeTab"]
}
